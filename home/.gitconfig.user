[commit]
  gpgsign = true
[fetch]
  prune = true
[pull]
	rebase = true
[rebase]
  autoStash = true
[core]
  filemode = true
  pager = "diff-so-fancy | less --tabs=4 -RFX"
[include]
  path = ~/.gitconfig.work 


