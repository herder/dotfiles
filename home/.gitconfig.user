[user]
	name = Niklas Herder
  email = niklas.herder@gmail.com
  useConfigOnly = true
  signingkey = ~/.ssh/id_ed25519 
[gpg]
  format = ssh
[commit]
  gpgsign = true
[fetch]
  prune = true
[pull]
	rebase = true
[rebase]
  autoStash = true
[core]
  filemode = true
[include]
  path = ~/.gitconfig.work 
  path = ~/.gitconfig.diff

[url "ssh://git@github.com/"]
  insteadOf = "https://github.com/"


