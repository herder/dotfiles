[user]
	name = Niklas Herder
  email = niklas.herder@gmail.com
  useConfigOnly = true
  signingkey = ~/.ssh/id_ed25519 
[gpg]
  format = ssh
[commit]
  gpgsign = true
[fetch]
  prune = true
[pull]
	rebase = true
[rebase]
  autoStash = true
[core]
  filemode = true
  pager = "diff-so-fancy | less --tabs=4 -RFX"
[include]
  path = ~/.gitconfig.work 


