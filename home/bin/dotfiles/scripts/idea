#!/usr/bin/env bash
# The default Intellij IDEA script doesn't handle relative paths, which makes it
# impossible to open a pom with idea pom.xml, for example.
# This script fixes that.

REAL_IDEA_SCRIPT=`which -a idea | head -n2 | tail -n1`
ARGS="$@"
if [ ! -z "$1" ]; then
  ARGS=${ARGS/$1/`greadlink -f $1`}
fi
$REAL_IDEA_SCRIPT $ARGS
